---
import Layout from '../layouts/Layout.astro';
import Home from '../components/Home';
import ThemeToggle from '../components/ThemeToggle';
---

<Layout 
	title="KTOOTH - Creative & Productivity Tools"
	description="Suite of tools for writers and creators."
	canonicalUrl="https://donotstopwriting.com"
	hideScrollTop={true}
>
	<header class="h-24 absolute top-0 left-0 right-0 z-[100] bg-transparent">
		<div class="relative w-full h-full flex items-center px-8 md:px-12">
			<!-- Removed old logo -->
		</div>
	</header>

	<div class="absolute top-4 right-16 z-[100] flex items-center h-12">
		<ThemeToggle client:load />
	</div>

	<!-- Scroll to top button -->
	<button
		id="scroll-top-btn"
		aria-label="Scroll to top"
		style="position: fixed; bottom: 2rem; right: 2rem; z-index: 99; width: 44px; height: 44px; border-radius: 50%; border: 1px solid rgba(0,0,0,0.1); background: rgba(255,255,255,0.85); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); cursor: pointer; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.35s ease; box-shadow: 0 2px 12px rgba(0,0,0,0.08);"
	>
		<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
			<path d="M18 15l-6-6-6 6"/>
		</svg>
	</button>
	
	<main>
		<Home client:load />
	</main>

	<!-- Scroll-to-top script -->
	<script is:inline>
		var isBtnVisible = false;

		function onScroll() {
			var btn = document.getElementById('scroll-top-btn');
			var scrollY = window.pageYOffset || document.documentElement.scrollTop || 0;

			// Scroll-to-top button (optimized state guard)
			var currentlyBtnVisible = scrollY > 300;
			if (currentlyBtnVisible !== isBtnVisible) {
				isBtnVisible = currentlyBtnVisible;
				if (btn) {
					if (isBtnVisible) {
						btn.style.opacity = '1';
						btn.style.pointerEvents = 'auto';
					} else {
						btn.style.opacity = '0';
						btn.style.pointerEvents = 'none';
					}
				}
			}
		}

		// Scroll-to-top click handler + hover glow
		var topBtn = document.getElementById('scroll-top-btn');
		if (topBtn) {
			topBtn.style.transition = 'opacity 0.35s ease, transform 0.2s ease, box-shadow 0.2s ease';
			topBtn.addEventListener('click', function() {
				window.scrollTo({ top: 0, behavior: 'smooth' });
			});
			topBtn.addEventListener('mouseenter', function() {
				topBtn.style.transform = 'scale(1.08)';
				topBtn.style.boxShadow = document.documentElement.classList.contains('dark')
					? '0 4px 20px rgba(0,0,0,0.5), 0 0 0 3px rgba(255,255,255,0.06)'
					: '0 4px 20px rgba(0,0,0,0.14), 0 0 0 3px rgba(0,0,0,0.05)';
			});
			topBtn.addEventListener('mouseleave', function() {
				topBtn.style.transform = 'scale(1)';
				topBtn.style.boxShadow = '0 2px 12px rgba(0,0,0,0.08)';
			});
		}

		// Dark mode styling for the button
		var isDark = document.documentElement.classList.contains('dark');
		if (isDark && topBtn) {
			topBtn.style.background = 'rgba(30,30,30,0.85)';
			topBtn.style.borderColor = 'rgba(255,255,255,0.1)';
			topBtn.style.color = '#e5e5e5';
		}

		// Watch for theme changes
		var observer = new MutationObserver(function() {
			var btn2 = document.getElementById('scroll-top-btn');
			if (!btn2) return;
			if (document.documentElement.classList.contains('dark')) {
				btn2.style.background = 'rgba(30,30,30,0.85)';
				btn2.style.borderColor = 'rgba(255,255,255,0.1)';
				btn2.style.color = '#e5e5e5';
			} else {
				btn2.style.background = 'rgba(255,255,255,0.85)';
				btn2.style.borderColor = 'rgba(0,0,0,0.1)';
				btn2.style.color = '#111111';
			}
		});
		observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

		window.addEventListener('scroll', onScroll);
		onScroll();
	</script>
</Layout>
