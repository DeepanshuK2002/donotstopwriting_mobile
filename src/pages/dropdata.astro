---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle';
---

<Layout 
	title="dropdata - Premium Local Sharing"
	description="A modern, ad-free, privacy-focused alternative for global and nearby file sharing."
>
	<div id="dropdata-root" class="dropdata-page min-h-screen text-slate-800 dark:text-slate-100 font-serif flex flex-col overflow-x-hidden">
		
		<!-- App Header (Old Style - Serif, Lowercase, Centered) -->
		<header id="app-header" class="h-24 relative z-[100] bg-transparent shrink-0">
			<div class="relative w-full h-full flex items-center px-8 md:px-12">
				<!-- Back to Modes (only shown when not on landing) -->
				<button id="btn-header-back" class="hidden p-3 -ml-3 text-neutral-500 hover:text-primary dark:text-neutral-400 bg-transparent border-0 cursor-pointer transition-colors" aria-label="Back">
					<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
				</button>

				<!-- Centered Brand Title (Old Style) -->
				<a
					href="/index.html"
					class="absolute left-1/2 -translate-x-1/2 text-[19px] font-serif tracking-wide text-primary dark:text-neutral-100 lowercase select-none hover:opacity-85 no-underline"
				>
					dropdata
				</a>

				<div class="ml-auto flex items-center gap-2">
					<ThemeToggle client:load />
				</div>
			</div>
		</header>

		<!-- View 1: Mode Selection (Landing) -->
		<section id="view-landing" class="flex-1 flex flex-col items-center justify-center px-6 animate-fade-in relative z-10">
			<div class="text-center mb-16 space-y-4">
				<h1 class="text-[48px] md:text-[64px] font-serif leading-[0.92] tracking-tight text-primary dark:text-neutral-100 font-medium">
					Share files.<br />Your way.
				</h1>
				<p class="text-[15px] text-slate-400 dark:text-slate-500 font-serif italic tracking-wide">
					Choose your sharing mode.
				</p>
			</div>

			<div class="grid grid-cols-2 gap-4 w-full max-w-sm">
				<button id="btn-mode-web" class="group flex flex-col items-center justify-center p-8 bg-white/40 dark:bg-white/5 backdrop-blur-xl border border-black/5 dark:border-white/5 rounded-xl hover:bg-white/60 dark:hover:bg-white/10 transition-all duration-300 cursor-pointer focus:outline-none">
					<div class="mb-4 text-blue-500 dark:text-blue-400 group-hover:scale-110 transition-transform duration-300">
						<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
					</div>
					<h2 class="text-lg font-bold text-primary dark:text-white mb-1 font-sans">Web</h2>
					<span class="text-[8px] uppercase tracking-[0.15em] font-bold text-blue-500/60 dark:text-blue-400/60">Global</span>
				</button>

				<button id="btn-mode-local" class="group flex flex-col items-center justify-center p-8 bg-white/40 dark:bg-white/5 backdrop-blur-xl border border-black/5 dark:border-white/5 rounded-xl hover:bg-white/60 dark:hover:bg-white/10 transition-all duration-300 cursor-pointer focus:outline-none">
					<div class="mb-4 text-emerald-500 dark:text-emerald-400 group-hover:scale-110 transition-transform duration-300">
						<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 11 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>
					</div>
					<h2 class="text-lg font-bold text-primary dark:text-white mb-1 font-sans">Local</h2>
					<span class="text-[8px] uppercase tracking-[0.15em] font-bold text-emerald-500/60 dark:text-emerald-400/60">Offline</span>
				</button>
			</div>
		</section>

		<!-- View 2: Web Mode -->
		<section id="view-web" class="hidden flex-1 flex flex-col items-center justify-center px-4 relative z-10 animate-fade-in">
			<div class="text-center pb-12">
				<h1 class="text-[48px] md:text-[64px] font-serif leading-[0.92] tracking-tight mb-5 text-primary dark:text-neutral-100 font-medium">Drop once.<br />Receive instantly.</h1>
				<p class="text-[13px] md:text-sm text-slate-400 dark:text-slate-500 font-serif italic tracking-wide">secure peer-to-peer file sharing.</p>
			</div>
			<div class="w-full max-w-[450px] mx-auto text-center">
				<div class="app-card bg-white/70 dark:bg-slate-950/40 backdrop-blur-2xl border-2 border-black/10 dark:border-white/10 rounded-xl p-6 shadow-none text-center w-full relative overflow-hidden transition-all duration-300">
					<div id="web-tabs-container" class="relative flex p-1 bg-slate-200/50 dark:bg-black/40 rounded-full border border-slate-350 dark:border-white/5 mb-6 select-none">
						<div id="web-tab-indicator" class="absolute top-1 bottom-1 left-1 w-[calc(50%-4px)] bg-blue-500/10 dark:bg-blue-500/20 border border-blue-500/20 rounded-full transition-transform duration-300 ease-out z-0"></div>
						<button id="web-tab-send" class="relative z-10 flex-1 text-center py-2 text-xs font-bold rounded-full transition-colors duration-200 text-blue-600 dark:text-white cursor-pointer focus:outline-none bg-transparent border-0">Send</button>
						<button id="web-tab-receive" class="relative z-10 flex-1 text-center py-2 text-xs font-bold rounded-full transition-colors duration-200 text-slate-500 dark:text-slate-400 hover:text-slate-900 hover:dark:text-white cursor-pointer focus:outline-none bg-transparent border-0">Receive</button>
					</div>
					<div class="relative min-h-[160px] flex flex-col justify-center">
						<div id="web-panel-send" class="space-y-5"><button id="btn-create-room" class="w-full py-4 px-4 bg-slate-900 text-white dark:bg-white dark:text-black rounded-xl text-sm font-bold shadow-md cursor-pointer border-0">Generate Code</button></div>
						<div id="web-panel-receive" class="space-y-5 hidden">
							<input type="text" id="input-room-code" inputmode="numeric" placeholder="000-000-000" maxlength="11" class="w-full py-3 px-4 rounded-xl bg-slate-100 dark:bg-black/40 border border-slate-350 dark:border-white/10 text-center text-md font-mono tracking-widest text-slate-900 dark:text-white focus:outline-none"/>
							<button id="btn-connect-room" class="w-full py-3 px-4 bg-blue-500 text-white rounded-xl text-xs font-bold shadow-md border-0 cursor-pointer">Connect</button>
						</div>
					</div>
				</div>
				<div class="mt-8">
					<button onclick="window.location.reload()" class="text-[10px] uppercase tracking-[0.2em] text-slate-400 dark:text-slate-600 hover:text-primary transition-colors bg-transparent border-0 cursor-pointer font-sans font-medium">RESET TOOL</button>
				</div>
			</div>
		</section>

		<!-- View 3: DropData Local (Dashboard) -->
		<section id="view-local" class="hidden flex-1 flex flex-col animate-fade-in relative z-10 px-6">

			<!-- Reduced Font Headline -->
			<div class="text-center pt-8 pb-12 space-y-2">
				<h1 class="text-3xl md:text-4xl font-serif font-medium text-primary dark:text-neutral-100">
					Local Sharing
				</h1>
				<p class="text-[13px] md:text-sm text-slate-400 dark:text-slate-500 font-serif italic tracking-wide">
					Connect with nearby devices.
				</p>
			</div>

			<!-- Main Actions -->
			<div class="flex items-center justify-around py-8 mb-4">
				<button id="local-action-send" class="group flex flex-col items-center gap-4 bg-transparent border-0 cursor-pointer focus:outline-none">
					<div class="w-24 h-24 bg-blue-600 dark:bg-blue-500 text-white rounded-full flex items-center justify-center shadow-lg group-hover:scale-105 active:scale-95 transition-all duration-300">
						<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
					</div>
					<span class="text-xs font-bold text-slate-700 dark:text-slate-300 tracking-widest uppercase">Send</span>
				</button>

				<button id="local-action-receive" class="group flex flex-col items-center gap-4 bg-transparent border-0 cursor-pointer focus:outline-none">
					<div class="w-24 h-24 bg-emerald-600 dark:bg-emerald-500 text-white rounded-full flex items-center justify-center shadow-lg group-hover:scale-105 active:scale-95 transition-all duration-300">
						<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
					</div>
					<span class="text-xs font-bold text-slate-700 dark:text-slate-300 tracking-widest uppercase">Receive</span>
				</button>
			</div>

			<!-- Inline Horizontal Scroll bar for Modules -->
			<div class="w-full overflow-x-auto no-scrollbar py-6 border-y border-black/5 dark:border-white/5 flex items-center gap-8 px-2 mb-12">
				<button id="mod-files" class="flex items-center gap-2.5 bg-transparent border-0 cursor-pointer opacity-80 hover:opacity-100 transition-opacity shrink-0">
					<div class="w-11 h-11 bg-orange-500/10 rounded-xl flex items-center justify-center text-orange-500"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg></div>
					<span class="text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest">Files</span>
				</button>
				<button id="mod-photos" class="flex items-center gap-2.5 bg-transparent border-0 cursor-pointer opacity-80 hover:opacity-100 transition-opacity shrink-0">
					<div class="w-11 h-11 bg-pink-500/10 rounded-xl flex items-center justify-center text-pink-500"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>
					<span class="text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest">Photos</span>
				</button>
				<button id="mod-videos" class="flex items-center gap-2.5 bg-transparent border-0 cursor-pointer opacity-80 hover:opacity-100 transition-opacity shrink-0">
					<div class="w-11 h-11 bg-purple-500/10 rounded-xl flex items-center justify-center text-purple-500"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/><line x1="17" y1="17" x2="22" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/></svg></div>
					<span class="text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest">Videos</span>
				</button>
				<button id="mod-music" class="flex items-center gap-2.5 bg-transparent border-0 cursor-pointer opacity-80 hover:opacity-100 transition-opacity shrink-0">
					<div class="w-11 h-11 bg-indigo-500/10 rounded-xl flex items-center justify-center text-indigo-500"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg></div>
					<span class="text-[10px] font-bold text-slate-500 dark:text-slate-400 uppercase tracking-widest">Music</span>
				</button>
			</div>

			<!-- Device Discovery Card (No scanning here by default) -->
			<div class="bg-white/40 dark:bg-white/5 backdrop-blur-2xl border border-black/5 dark:border-white/5 rounded-xl p-8 text-center space-y-4">
				<div class="w-16 h-16 bg-blue-500/10 text-blue-500 rounded-full flex items-center justify-center mx-auto">
					<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
				</div>
				<h3 class="text-sm font-bold text-primary dark:text-white uppercase tracking-widest">Ready for Transfer</h3>
				<p class="text-xs text-slate-400 dark:text-slate-500 px-8 leading-relaxed">Select "Send" or "Receive" to start finding nearby devices.</p>
			</div>

			<!-- Bottom Tools -->
			<div class="py-12 text-center flex flex-col items-center gap-6">
				<button id="btn-local-reset" class="text-[10px] uppercase tracking-[0.3em] text-slate-400 dark:text-slate-600 hover:text-primary transition-all bg-transparent border-0 cursor-pointer font-bold">RESET TOOL</button>
				<button id="btn-back-selection" class="px-6 py-2 border border-black/10 dark:border-white/10 rounded-full text-[9px] uppercase tracking-widest font-bold text-slate-500 hover:bg-black/5 transition-all bg-transparent cursor-pointer">SWITCH MODE</button>
			</div>
		</section>

		<!-- Sub-View: File Picker / Send List (Includes scanning here) -->
		<section id="view-picker" class="hidden flex-1 flex flex-col animate-fade-in bg-white dark:bg-[#111111] z-50">
			<div class="h-20 flex items-center px-8 shrink-0">
				<button id="btn-picker-back" class="p-3 -ml-3 text-neutral-500 hover:text-primary bg-transparent border-0 cursor-pointer"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg></button>
				<h2 id="picker-title" class="text-sm font-bold uppercase tracking-widest text-primary dark:text-white ml-2">Select Items</h2>
			</div>

			<!-- Dynamic Scanning Bar -->
			<div class="px-8 py-4 bg-emerald-500/5 flex items-center justify-between border-y border-emerald-500/10">
				<div class="flex items-center gap-3">
					<div class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></div>
					<span class="text-[10px] font-bold text-emerald-600 dark:text-emerald-400 uppercase tracking-widest">Searching for nearby receivers</span>
				</div>
				<span class="text-[9px] font-bold text-slate-400 uppercase">Auto-discovery</span>
			</div>

			<div class="flex-1 overflow-y-auto px-6 pt-6 pb-24 custom-scrollbar">
				<div class="grid grid-cols-3 gap-2" id="picker-grid">
					<!-- Dynamically populated -->
				</div>
			</div>

			<div class="fixed bottom-0 left-0 right-0 p-8 bg-white/80 dark:bg-[#111111]/80 backdrop-blur-xl border-t border-black/5 dark:border-white/5 flex items-center justify-between z-[60]">
				<div class="space-y-1">
					<p id="picker-count" class="text-sm font-bold text-primary dark:text-white">0 Items Selected</p>
					<p id="picker-size" class="text-[10px] text-slate-400 uppercase font-bold tracking-widest">0.00 MB Total</p>
				</div>
				<button id="btn-send-now" class="px-12 py-5 bg-blue-600 text-white rounded-2xl font-bold text-xs uppercase tracking-widest shadow-xl shadow-blue-500/20 border-0 cursor-pointer active:scale-95 transition-all">Send Now</button>
			</div>
		</section>

		<!-- Minimal Footer -->
		<footer id="app-footer" class="py-8 text-center text-[10px] text-slate-400 dark:text-slate-600 shrink-0">
			<p>&copy; 2026 donotstopwriting.com / dropdata local</p>
		</footer>

	</div>
</Layout>

<script is:inline>
	(function() {
		// --- View Management ---
		const views = {
			landing: document.getElementById('view-landing'),
			web: document.getElementById('view-web'),
			local: document.getElementById('view-local'),
			picker: document.getElementById('view-picker')
		};

		const header = document.getElementById('app-header');
		const footer = document.getElementById('app-footer');
		const btnHeaderBack = document.getElementById('btn-header-back');
		const btnBackMain = document.getElementById('btn-back-main');

		function showView(viewId) {
			Object.values(views).forEach(v => v.classList.add('hidden'));
			views[viewId].classList.remove('hidden');

			if (viewId === 'landing') {
				btnHeaderBack.classList.add('hidden');
				btnBackMain.classList.remove('hidden');
				header.classList.remove('hidden');
				footer.classList.remove('hidden');
			} else if (viewId === 'picker') {
				header.classList.add('hidden');
				footer.classList.add('hidden');
			} else {
				btnHeaderBack.classList.remove('hidden');
				btnBackMain.classList.add('hidden');
				header.classList.remove('hidden');
				footer.classList.remove('hidden');
			}
		}

		// Navigation Triggers
		document.getElementById('btn-mode-web').addEventListener('click', () => showView('web'));
		document.getElementById('btn-mode-local').addEventListener('click', () => showView('local'));
		document.getElementById('btn-header-back').addEventListener('click', () => showView('landing'));
		document.getElementById('btn-web-back').addEventListener('click', () => showView('landing'));
		document.getElementById('btn-back-selection').addEventListener('click', () => showView('landing'));
		document.getElementById('btn-local-reset').addEventListener('click', () => window.location.reload());

		// Picker Functionality
		const pickerTitle = document.getElementById('picker-title');
		const pickerGrid = document.getElementById('picker-grid');
		const modButtons = ['mod-files', 'mod-photos', 'mod-videos', 'mod-music'];

		modButtons.forEach(id => {
			document.getElementById(id)?.addEventListener('click', () => {
				const type = id.split('-')[1];
				pickerTitle.innerText = `Select ${type}`;
				showView('picker');
				pickerGrid.innerHTML = '';
				for(let i=0; i<18; i++) {
					const div = document.createElement('div');
					div.className = 'aspect-square bg-black/5 dark:bg-white/5 rounded-xl border border-black/5 dark:border-white/5 animate-fade-in';
					div.style.animationDelay = `${i * 30}ms`;
					pickerGrid.appendChild(div);
				}
			});
		});

		document.getElementById('btn-picker-back').addEventListener('click', () => showView('local'));
		document.getElementById('local-action-send').addEventListener('click', () => {
			pickerTitle.innerText = "Select Items";
			showView('picker');
		});

		// Web Mode Tab Logic
		const webTabSend = document.getElementById('web-tab-send');
		const webTabReceive = document.getElementById('web-tab-receive');
		const webTabIndicator = document.getElementById('web-tab-indicator');
		const webPanelSend = document.getElementById('web-panel-send');
		const webPanelReceive = document.getElementById('web-panel-receive');

		webTabSend.addEventListener('click', () => {
			webTabIndicator.style.transform = 'translateX(0)';
			webTabSend.classList.add('text-blue-600'); webTabReceive.classList.remove('text-blue-600');
			webPanelSend.classList.remove('hidden'); webPanelReceive.classList.add('hidden');
		});

		webTabReceive.addEventListener('click', () => {
			webTabIndicator.style.transform = 'translateX(100%)';
			webTabReceive.classList.add('text-blue-600'); webTabSend.classList.remove('text-blue-600');
			webPanelSend.classList.add('hidden'); webPanelReceive.classList.remove('hidden');
		});

	})();
</script>

<style>
	.dropdata-page {
		background: radial-gradient(130% 80% at 50% 0%, #bfdbfe 0%, #FAF7F6 45%, #FAF7F6 100%);
		transition: background 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}
	:global(.dark) .dropdata-page {
		background: radial-gradient(130% 80% at 50% 0%, #1e40af 0%, #0f172a 45%, #030712 100%);
	}
	* { scrollbar-width: none !important; -ms-overflow-style: none !important; }
	*::-webkit-scrollbar { display: none !important; width: 0 !important; height: 0 !important; }
	.animate-fade-in { animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
	@keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
	.no-scrollbar::-webkit-scrollbar { display: none; }
</style>
