---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle';
---

<Layout
	title="Settings - KTOOTH"
	description="App settings and information."
>
	<div class="relative min-h-screen bg-[#FAF7F6] dark:bg-[#111111] transition-colors duration-300 font-serif">
		<!-- Header -->
		<header class="sticky top-0 z-50 bg-white/80 dark:bg-[#1C1C1E]/80 backdrop-blur-md border-b border-neutral-200 dark:border-neutral-800">
			<div class="max-w-lg mx-auto px-6 h-16 flex items-center justify-between">
				<a href="/index.html" class="p-2 -ml-2 text-neutral-500 hover:text-primary dark:text-neutral-400 no-underline transition-colors">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="m15 18-6-6 6-6"/>
					</svg>
				</a>
				<h1 class="text-lg font-bold tracking-tight text-primary dark:text-neutral-100 uppercase">Settings</h1>
				<ThemeToggle client:load />
			</div>
		</header>

		<main class="max-w-lg mx-auto px-6 py-8 space-y-4">
			<!-- Accordion Items -->
			<div class="space-y-3">
				<details class="group bg-white dark:bg-[#1C1C1E] border border-neutral-200 dark:border-neutral-800 rounded-xl overflow-hidden shadow-sm transition-all duration-300">
					<summary class="flex items-center justify-between p-5 cursor-pointer list-none">
						<span class="text-base font-bold text-primary dark:text-neutral-100">About</span>
						<svg class="w-5 h-5 text-neutral-400 transition-transform duration-300 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="m6 9 6 6 6-6"/>
						</svg>
					</summary>
					<div class="px-5 pb-6 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400 space-y-4 font-sans">
						<p><strong>Do Not Stop Writing</strong> is a free online writing tool designed to help writers, students, bloggers, authors, and content creators overcome writer's block.</p>
						<p>Developed by Deepanshu Kashyap, this tool challenges you to keep moving forward and focus on creating instead of perfecting.</p>
						<p class="italic border-l-2 border-[#E52525] pl-3">This site is completely open source.</p>
					</div>
				</details>

				<!-- 2. Contact -->
				<details class="group bg-white dark:bg-[#1C1C1E] border border-neutral-200 dark:border-neutral-800 rounded-xl overflow-hidden shadow-sm transition-all duration-300">
					<summary class="flex items-center justify-between p-5 cursor-pointer list-none">
						<span class="text-base font-bold text-primary dark:text-neutral-100">Contact</span>
						<svg class="w-5 h-5 text-neutral-400 transition-transform duration-300 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="m6 9 6 6 6-6"/>
						</svg>
					</summary>
					<div class="px-5 pb-6 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400 space-y-4 font-sans">
						<p>Whether you've found a bug, have a feature request, or just want to say hello — reach out using the form below or email us directly.</p>
						<div class="p-4 bg-neutral-50 dark:bg-black/20 rounded-xl border border-neutral-100 dark:border-neutral-800">
							<p class="font-bold text-primary dark:text-neutral-200">Email:</p>
							<p>allrecord77-@gmail.com</p>
						</div>
						<a href="/contact/index.html" class="inline-block px-4 py-2 bg-black dark:bg-white text-white dark:text-black rounded-lg text-xs font-bold no-underline">Open Contact Form</a>
					</div>
				</details>

				<!-- 3. Tools -->
				<details class="group bg-white dark:bg-[#1C1C1E] border border-neutral-200 dark:border-neutral-800 rounded-xl overflow-hidden shadow-sm transition-all duration-300">
					<summary class="flex items-center justify-between p-5 cursor-pointer list-none">
						<span class="text-base font-bold text-primary dark:text-neutral-100">Our Tools</span>
						<svg class="w-5 h-5 text-neutral-400 transition-transform duration-300 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="m6 9 6 6 6-6"/>
						</svg>
					</summary>
					<div class="px-5 pb-6 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400 space-y-4 font-sans">
						<ul class="space-y-3 list-none p-0">
							<li class="flex items-center gap-3 p-3 bg-neutral-50 dark:bg-black/20 rounded-xl">
								<img src="/original-icon.png" class="w-8 h-8 rounded-md" />
								<div>
									<p class="font-bold text-primary dark:text-neutral-200">Do Not Stop Writing</p>
									<p class="text-[11px]">The dangerous writing app.</p>
								</div>
							</li>
							<li class="flex items-center gap-3 p-3 bg-neutral-50 dark:bg-black/20 rounded-xl">
								<img src="/dropdata-icon.png" class="w-8 h-8 rounded-md" />
								<div>
									<p class="font-bold text-primary dark:text-neutral-200">DropData</p>
									<p class="text-[11px]">P2P secure file sharing.</p>
								</div>
							</li>
						</ul>
					</div>
				</details>

				<!-- 4. Privacy Policy -->
				<details class="group bg-white dark:bg-[#1C1C1E] border border-neutral-200 dark:border-neutral-800 rounded-xl overflow-hidden shadow-sm transition-all duration-300">
					<summary class="flex items-center justify-between p-5 cursor-pointer list-none">
						<span class="text-base font-bold text-primary dark:text-neutral-100">Privacy Policy</span>
						<svg class="w-5 h-5 text-neutral-400 transition-transform duration-300 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="m6 9 6 6 6-6"/>
						</svg>
					</summary>
					<div class="px-5 pb-6 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400 space-y-4 font-sans max-h-80 overflow-y-auto custom-scrollbar">
						<p class="font-bold">We do not require you to provide any personal information.</p>
						<p><strong>Writing Tool:</strong> content is stored only in-memory and never transmitted to our servers.</p>
						<p><strong>dropdata:</strong> transfers files directly between browsers using WebRTC. No files are uploaded to our servers.</p>
						<p>We use browser local storagestrictly to save your theme selection.</p>
					</div>
				</details>

				<!-- 5. Terms & Conditions -->
				<details class="group bg-white dark:bg-[#1C1C1E] border border-neutral-200 dark:border-neutral-800 rounded-xl overflow-hidden shadow-sm transition-all duration-300">
					<summary class="flex items-center justify-between p-5 cursor-pointer list-none">
						<span class="text-base font-bold text-primary dark:text-neutral-100">Terms & Conditions</span>
						<svg class="w-5 h-5 text-neutral-400 transition-transform duration-300 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
							<path d="m6 9 6 6 6-6"/>
						</svg>
					</summary>
					<div class="px-5 pb-6 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400 space-y-4 font-sans max-h-80 overflow-y-auto custom-scrollbar">
						<p>By using Do Not Stop Writing, you agree to these Terms.</p>
						<p><strong>Disclaimer:</strong> Text may be automatically deleted when writing stops. We are not responsible for recovering deleted or lost content.</p>
						<p>Files shared via dropdata are the sole responsibility of the user.</p>
						<p>The Service is provided on an "as is" basis without warranty.</p>
					</div>
				</details>
			</div>

			<div class="pt-12 text-center select-none">
				<p class="text-[10px] uppercase tracking-widest text-neutral-400 dark:text-neutral-600 font-sans font-bold">KTOOTH v1.0.0</p>
				<p class="text-xs text-neutral-400 dark:text-neutral-500 mt-1">© 2026 Deepanshu Kashyap</p>
			</div>
		</main>
	</div>
</Layout>

<style>
	/* Hide default arrow in some browsers */
	details summary::-webkit-details-marker {
		display: none;
	}

	.custom-scrollbar::-webkit-scrollbar {
		width: 4px;
	}
	.custom-scrollbar::-webkit-scrollbar-thumb {
		background: rgba(0,0,0,0.1);
		border-radius: 10px;
	}
	:global(.dark) .custom-scrollbar::-webkit-scrollbar-thumb {
		background: rgba(255,255,255,0.1);
	}
</style>
