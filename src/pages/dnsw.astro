---
import Layout from '../layouts/Layout.astro';
import Home from '../components/Home_DNSW';
import ThemeToggle from '../components/ThemeToggle';
---

<Layout
	title="Do Not Stop Writing - The Dangerous Writing App"
	description="Beat writer's block and enter flow state instantly. Do Not Stop Writing is a dangerous writing app that deletes your text if you stop typing for too long. Try the ultimate distraction-free writing challenge."
	canonicalUrl="https://donotstopwriting.com"
	hideScrollTop={true}
>
	<header class="h-24 absolute top-0 left-0 right-0 z-[100] bg-transparent">
		<div class="relative w-full h-full flex items-center px-8 md:px-12">
			<a
				href="/index.html"
				id="logo"
				class="absolute text-[19px] font-serif tracking-wide text-primary dark:text-neutral-100 lowercase select-none hover:opacity-85 no-underline"
				style="left: 50%; transform: translateX(-50%);"
			>
				donotstopwriting.com
			</a>
		</div>
	</header>

	<!-- Home Button (Top Left) -->
	<div class="absolute top-6 left-8 md:left-12 z-[100] flex items-center h-12">
		<a
			href="/index.html"
			class="p-3 text-neutral-500 hover:text-primary dark:text-neutral-400 dark:hover:text-white hover:bg-neutral-100 dark:hover:bg-neutral-900 rounded-full transition-colors cursor-pointer focus:outline-none no-underline"
			aria-label="Back to Home"
		>
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
				<polyline points="9 22 9 12 15 12 15 22"></polyline>
			</svg>
		</a>
	</div>

	<!-- Sticky Theme Toggle (Top Right) -->
	<div class="absolute top-6 right-8 md:right-12 z-[100] flex items-center h-12">
		<ThemeToggle client:load />
	</div>

	<main>
		<Home client:load />
	</main>
</Layout>
