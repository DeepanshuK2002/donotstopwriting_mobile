---
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
	canonicalUrl?: string;
	robots?: string;
	hideScrollTop?: boolean;
}

const { 
	title = "Do Not Stop Writing - The Dangerous Writing App",
	description = "Defeat writer's block and get in the flow state instantly. Do Not Stop Writing is a dangerous writing app that deletes your progress if you stop typing.",
	canonicalUrl = "https://donotstopwriting.com",
	robots,
	hideScrollTop = false
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- SEO Meta Tags -->
		{robots && <meta name="robots" content={robots} />}
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="https://donotstopwriting.com/og-image.jpg" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalUrl} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content="https://donotstopwriting.com/og-image.jpg" />

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@type": "WebApplication",
				"name": "Do Not Stop Writing",
				"url": "https://donotstopwriting.com",
				"description": "A minimalist, dangerous writing application that forces users to write continuously by deleting their work if they stop typing for too long. Helps writers beat writer's block and enter flow state.",
				"applicationCategory": "ProductivityApplication",
				"operatingSystem": "All",
				"offers": {
					"@type": "Offer",
					"price": "0",
					"priceCurrency": "USD"
				}
			}
		</script>

		<!-- Google Analytics -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-Z8K56WV409" is:inline></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-Z8K56WV409');
		</script>

		<script is:inline>
			const theme = (() => {
			if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
				return localStorage.getItem('theme');
			}
			// Default to light mode unless user has explicitly chosen dark
			return 'light';
		})();

		if (theme === 'light') {
			document.documentElement.classList.remove('dark');
		} else {
			document.documentElement.classList.add('dark');
		}
		window.localStorage.setItem('theme', theme);

		// OS check to apply custom macOS cursor/scrollbar on Windows & Linux
		if (typeof navigator !== 'undefined' && !/Mac|iPhone|iPod|iPad/i.test(navigator.userAgent)) {
			document.documentElement.classList.add('custom-macos-theme');
		}
		</script>
	</head>
	<body class="min-h-screen bg-background text-primary dark:bg-[#111111] dark:text-neutral-100 transition-colors duration-300">
		<slot />

		{!hideScrollTop && (
			<button
				id="scroll-to-top"
				aria-label="Scroll to top"
				title="Back to top"
				class="scroll-top-btn"
			>
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<polyline points="18 15 12 9 6 15" />
				</svg>
			</button>
		)}

		{!hideScrollTop && (
			<script is:inline>
				(function () {
					const btn = document.getElementById('scroll-to-top');
					if (!btn) return;

					// Show/hide on scroll
					window.addEventListener('scroll', function () {
						if (window.scrollY > 300) {
							btn.classList.add('visible');
						} else {
							btn.classList.remove('visible');
						}
					}, { passive: true });

					// Scroll to top on click
					btn.addEventListener('click', function () {
						window.scrollTo({ top: 0, behavior: 'smooth' });
					});

					// Initial dark mode styling
					function applyTheme() {
						if (document.documentElement.classList.contains('dark')) {
							btn.style.background = 'rgba(30,30,30,0.85)';
							btn.style.borderColor = 'rgba(255,255,255,0.1)';
							btn.style.color = '#e5e5e5';
						} else {
							btn.style.background = 'rgba(255,255,255,0.85)';
							btn.style.borderColor = 'rgba(0,0,0,0.1)';
							btn.style.color = '#111111';
						}
					}
					applyTheme();

					// Watch for theme changes
					new MutationObserver(applyTheme).observe(
						document.documentElement,
						{ attributes: true, attributeFilter: ['class'] }
					);
				})();
			</script>
		)}
	</body>
</html>

<style is:global>
	:root {
		--font-sans: "Geist", "Inter", ui-sans-serif, system-ui, sans-serif;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		overflow-x: hidden;
	}

	/* Vercel-like scrollbar for native macOS or other defaults */
	::-webkit-scrollbar {
		width: 8px;
		height: 8px;
	}
	::-webkit-scrollbar-track {
		background: transparent;
	}
	::-webkit-scrollbar-thumb {
		background: #888;
		border-radius: 10px;
	}
	::-webkit-scrollbar-thumb:hover {
		background: #555;
	}

	.dark ::-webkit-scrollbar-thumb {
		background: #333;
	}
	.dark ::-webkit-scrollbar-thumb:hover {
		background: #444;
	}

	/* macOS Style Cursors for Windows/Linux */
	.custom-macos-theme,
	.custom-macos-theme * {
		cursor: url("../assets/mac cursor/cursor.svg") 8 5, auto !important;
	}

	.custom-macos-theme a,
	.custom-macos-theme button,
	.custom-macos-theme select,
	.custom-macos-theme input[type="submit"],
	.custom-macos-theme input[type="button"],
	.custom-macos-theme [role="button"],
	.custom-macos-theme .cursor-pointer,
	.custom-macos-theme label,
	.custom-macos-theme a *,
	.custom-macos-theme button * {
		cursor: url("../assets/mac cursor/pointinghand.svg") 12 2, pointer !important;
	}

	.custom-macos-theme textarea,
	.custom-macos-theme input[type="text"],
	.custom-macos-theme input[type="number"],
	.custom-macos-theme input[type="email"],
	.custom-macos-theme input[type="password"],
	.custom-macos-theme input[type="search"],
	.custom-macos-theme [contenteditable] {
		cursor: text !important;
	}

	.custom-macos-theme :disabled,
	.custom-macos-theme .cursor-not-allowed,
	.custom-macos-theme [aria-disabled="true"] {
		cursor: url("../assets/mac cursor/notallowed.svg") 10 10, not-allowed !important;
	}

	.custom-macos-theme .cursor-grab,
	.custom-macos-theme [draggable="true"] {
		cursor: url("../assets/mac cursor/openhand.svg") 10 10, grab !important;
	}

	.custom-macos-theme .cursor-grabbing {
		cursor: url("../assets/mac cursor/closedhand.svg") 10 10, grabbing !important;
	}

	.custom-macos-theme .cursor-help {
		cursor: url("../assets/mac cursor/help.svg") 10 10, help !important;
	}

	.custom-macos-theme .cursor-zoom-in {
		cursor: url("../assets/mac cursor/zoomin.svg") 10 10, zoom-in !important;
	}

	.custom-macos-theme .cursor-zoom-out {
		cursor: url("../assets/mac cursor/zoomout.svg") 10 10, zoom-out !important;
	}

	.custom-macos-theme .cursor-move {
		cursor: url("../assets/mac cursor/move.svg") 10 10, move !important;
	}

	.custom-macos-theme .cursor-nesw-resize {
		cursor: url("../assets/mac cursor/resizenortheastsouthwest.svg") 10 10, nesw-resize !important;
	}

	/* macOS Style Scrollbar for Windows/Linux (WebKit) */
	.custom-macos-theme::-webkit-scrollbar {
		width: 8px;
		height: 8px;
	}
	.custom-macos-theme::-webkit-scrollbar-track {
		background: transparent;
	}
	.custom-macos-theme::-webkit-scrollbar-thumb {
		background: rgba(120, 120, 120, 0.4);
		border-radius: 10px;
		border: 2px solid transparent;
		background-clip: padding-box;
	}
	.custom-macos-theme::-webkit-scrollbar-thumb:hover {
		background: rgba(100, 100, 100, 0.7);
		border: 2px solid transparent;
		background-clip: padding-box;
	}

	.custom-macos-theme.dark::-webkit-scrollbar-thumb {
		background: rgba(150, 150, 150, 0.3);
		border: 2px solid transparent;
		background-clip: padding-box;
	}
	.custom-macos-theme.dark::-webkit-scrollbar-thumb:hover {
		background: rgba(180, 180, 180, 0.5);
		border: 2px solid transparent;
		background-clip: padding-box;
	}

	/* macOS Style Scrollbar for Windows/Linux (Firefox) */
	html.custom-macos-theme {
		scrollbar-width: thin;
		scrollbar-color: rgba(120, 120, 120, 0.4) transparent;
	}
	html.custom-macos-theme.dark {
		scrollbar-color: rgba(150, 150, 150, 0.3) transparent;
	}
</style>
